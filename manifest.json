{
    "name": "hide — the — slop",
    "description": "Allows the user to scan pages for AI generated text. All AI passages are identified and covered with \"AI SLOP.\"",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": [
        "storage"
    ],
    "icons": {
        "16": "images/icon16.png",
        "32": "images/icon32.png",
        "64": "images/icon64.png",
        "128": "images/icon128.png"
    },
    "content_scripts": [
        {
            "js": ["content.js"],
            "css": ["content.css"],
            "matches": [
                "https://*/*"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["image.jpg"],
            "matches": ["https://*/*"]
        }
    ],
    "host_permissions": [
        "https://*/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    }
  }